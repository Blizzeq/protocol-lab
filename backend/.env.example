# === Database (Supabase Postgres) ===
# Copy the EXACT connection string from the dashboard:
#   Supabase -> (your project) -> Connect -> "Transaction pooler" / ORMs
# and replace the "postgresql://" prefix with "postgresql+asyncpg://".
# The pooler host varies (aws-0-... or aws-1-...), so copy it verbatim from the dashboard.
#
# Template (port 6543 = transaction pooler):
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres

# === Frontend / CORS ===
CORS_ORIGINS=http://localhost:3000

# === Environment ===
ENVIRONMENT=development

# === MCP server ===
# The MCP server acts as this Protocol Lab user. Set to one of your API keys (pl_...).
# MCP_API_KEY=pl_xxx

# === Optional / upcoming ===
# REDIS_URL=redis://localhost:6379/0   (multi-instance real-time fan-out)
# JWT_SECRET=change-me-to-a-long-random-secret
